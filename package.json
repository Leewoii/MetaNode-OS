{
  "name": "metanode-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:launcher dev:gate dev:distribution",
    "dev:launcher": "npm --workspace apps/launcher run dev",
    "dev:gate": "npm --workspace apps/gate-worker run dev",
    "dev:distribution": "npm --workspace apps/distribution-api run dev",
    "build": "npm --workspaces run build",
    "build:launcher": "npm --workspace apps/launcher run tauri:build",
    "typecheck": "npm --workspaces run typecheck",
    "test": "npm --workspaces --if-present run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "typescript": "^5.8.3"
  }
}
