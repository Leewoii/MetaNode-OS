{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MetaNode OS",
  "version": "0.1.0",
  "identifier": "os.metanode.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MetaNode OS",
        "width": 980,
        "height": 680,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "deb", "appimage"],
    "icon": []
  }
}
